# Google Business Profile API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Business Profile Location ID (found in Google Business Profile URL)
# Example: https://business.google.com/locations/1234567890123456789
GOOGLE_BUSINESS_LOCATION_ID=your_location_id_here

# Optional: Google Cloud Project ID
GOOGLE_PROJECT_ID=your_project_id_here

# Review moderation API
REVIEWS_ADMIN_TOKEN=generate_a_long_random_token_here

# Turnstile configuration
# Add these after the Cloudflare Turnstile widget is created for the domain.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
