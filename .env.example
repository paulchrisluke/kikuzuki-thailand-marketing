# Google Business Profile API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_ADMIN_EMAILS=paulchrisluke@gmail.com
AUTH_COOKIE_SECRET=generate_a_long_random_token_here
GOOGLE_BUSINESS_ACCOUNT_ID=your_google_business_account_id_here
GOOGLE_BUSINESS_LOCATION_ID=your_google_business_location_id_here
GOOGLE_PUBSUB_TOPIC=projects/your-google-cloud-project/topics/your-topic
GOOGLE_PUBSUB_PUSH_TOKEN=generate_a_long_random_token_for_pubsub_push_url_here

# Optional: Google Cloud Project ID
GOOGLE_PROJECT_ID=your_project_id_here

# Review moderation API
# Used as a fallback bearer token and local moderation secret.
REVIEWS_ADMIN_TOKEN=generate_a_long_random_token_here

# Turnstile configuration
# Add these after the Cloudflare Turnstile widget is created for the domain.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
